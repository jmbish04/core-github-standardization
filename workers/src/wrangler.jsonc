	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				// Core Orchestrator for managing agent lifecycles
				"OrchestratorAgent",
				// Agent for retrofitting and refactoring code
				"RetrofitAgent",
				// WebSocket Room for real-time collaboration
				"RoomDO",
				// Gemini-powered AI Agent
				"GeminiAgent",
				// Planning Agent for task decomposition
				"PlannerAgent",
				// Repository Management Agent
				"RepoAgent",
				// Supervisor Agent for managing container tasks
				"Supervisor",
				// Deep Reasoning Agent for complex logic
				"DeepReasoningAgent",
				// Secure Sandbox Environment
				"Sandbox",
				// Owner/Admin Agent
				"OwnerAgent",
				// Research Agent for gathering information
				"ResearchAgent",
				// Incremental Discord channel scanner ingesting messages for analysis
				"DiscordResearchAgent",
				// Jules Overseer for session management
				"JulesOverseer",
				// Topic Research Orchestrator
				"TopicOrchestratorAgent",
				// Web Search Agent
				"WebSearchAgent",
				// Judge Agent for evaluating outputs
				"JudgeAgent",
				// Reporting Agent for generating summaries
				"ReportingAgent",
				// Agent for generating or editing landing pages
				"LandingPageAgent",
				// Agent for querying Cloudflare Documentation with GitHub context
				"CloudflareDocsAgent",
				// Deep Research Chat Agent built directly on Honi
				"DeepResearchChatAgent",
				// Autonomous agent for analyzing and remediating health check failures
				"HealthDiagnostician",
				// WebSocket fan-out hub for Jules events
				"JulesWebhookBroadcaster",
				// Monitors planning sessions
				"PlanningMonitor",
				// Monitors reverse engineering tasks
				"ReverseEngineeringMonitor",
				// Supervises planning orchestrators
				"PlanningSupervisorAgent",
				// Orchestrates planning workflows
				"PlanningOrchestratorAgent",
				// Orchestrator for Honi-compatible agents
				"HoniOrchestrator",
				// Consultant agent running on Honi
				"HoniConsultant",
				// Agent for managing workshops
				"WorkshopAgent",
				// Workshop agent covering CF Agents SDK
				"CfWorkshop_AgentsSdk",
				// Ensures code and APIs meet standardized guidelines
				"StandardizationAgent",
				// Maintains state and chat history for agent sessions
				"AgentSessionDO",
				// UX Design Agent — 5-phase pipeline (Jules + Stitch)
				"UxDesignAgent",
				// Jules PR Reviewer
				"JulesPrReviewer"
			]
		}
	],
	"workflows": [
		{
			"name": "GithubSearchWorkflow",
			"binding": "GITHUB_SEARCH_WORKFLOW",
			"class_name": "GithubSearchWorkflow"
		},
		{
			"name": "deep-research-workflow",
			"binding": "DEEP_RESEARCH_WORKFLOW",
			"class_name": "DeepResearchWorkflow"
		},
		{
			"name": "research-orchestrator",
			"binding": "RESEARCH_ORCHESTRATOR",
			"class_name": "ResearchOrchestrator"
		},
		{
			"name": "topic-research-workflow",
			"binding": "TOPIC_RESEARCH_WORKFLOW",
			"class_name": "TopicResearchWorkflow"
		},
		{
		{
			// Incremental Discord channel scanner — ingests messages from the
			// Cloudflare Developers Discord, analyses them with AI, and surfaces
			// highlights in the daily newsletter.
			"name": "discord-research-workflow",
			"binding": "DISCORD_RESEARCH_WORKFLOW",
			"class_name": "DiscordResearchWorkflow"
		},
		{
			"name": "planning-orchestrator",
			"binding": "PLANNING_ORCHESTRATOR",
			"class_name": "PlanningOrchestrator"
		}
	],
	"browser": {
		"binding": "BROWSER"
	},
	"r2_buckets": [
		{
			"binding": "PLAN_ARTIFACTS",
			"bucket_name": "core-github-api-plan-artifacts"
		},
		{
			"binding": "ARTIFACT_STORE",
			"bucket_name": "core-planning-artifacts"
		}
	],
	"kv_namespaces": [
		{
			"binding": "ETAG_KV",
			"id": "eed6ba4656704616acf168be80ba770a",
			"preview_id": "cfc441ebd1d8492497f49e88ae98aa2f"
		},
		{
			"binding": "COMMENTS_KV",
			"id": "82d47893d39a4b0fb574b1a760e06452"
