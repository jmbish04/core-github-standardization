{
	"name": "core-github-api",
	"main": "src/backend/src/index.ts",
	"compatibility_date": "2026-03-12",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// "minify": true,
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true,
			"persist": true,
			"head_sampling_rate": 1
		}
	},
	"vars": {
		"LOG_LEVEL": "debug",
		"AI_DEFAULT_PROVIDER": "worker-ai",
		"AI_DEFAULT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
		"GEMINI_MODEL": "gemini-3-pro-preview",
		"OPENAI_MODEL": "gpt-5.1",
		"DEFAULT_MODEL_REASONING": "@cf/openai/gpt-oss-120b",
		"DEFAULT_MODEL_STRUCTURED_RESPONSE": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
		"DEFAULT_MODEL_EMBEDDING": "@cf/baai/bge-large-en-v1.5",
		"DEFAULT_MODEL_RERANKER": "@cf/baai/bge-reranker-base",
		"HEALTH_SANDBOX_TIMEOUT_MS": 60000,
		"AI_GATEWAY_NAME": "core-github-api",
		"CLOUDFLARE_WORKER_NAME": "core-github-api",
		"GITHUB_OWNER": "jmbish04",
		"TEMPLATES_REPO_NAME": "core-repo-templates",
		"STANDARDIZATION_REPO_NAME": "core-github-standardization",
		"HEALTH_TEST_REPO_NAME": "testing-oktokit-commands",
		"BASE_URL": "https://core-github-api.hacolby.workers.dev",
		"MAX_AI_BUDGET": "50",
		"USE_OPENAI_MODELS": false,
		"GITHUB_REPO_STANDARDIZATION": "jmbish04/core-github-standardization",
		"GITHUB_ACTION_WORKER_DISPATCHER_URI": "https://api.github.com/repos/jmbish04/core-github-standardization/dispatches",
		"MCP_API_URL": "https://docs.mcp.cloudflare.com/mcp"
	},
	"containers": [
		{
			"class_name": "Sandbox",
			"image": "./container/Dockerfile",
			"max_instances": 5,
			"instance_type": {
				"vcpu": 1,
				"memory_mib": 4096,
				"disk_mb": 6144
			}
		}
	],
	"ai": {
		"binding": "AI"
	},
	// Configures 'wrangler' to treat .hbs files as Text modules (ES importable strings)
	// This allows `import template from "./file.hbs"` to work natively in Workers.
	"rules": [
		{
			"type": "Text",
			"globs": [
				"**/*.hbs",
				"**/*.md",
				"**/*.yml",
				"**/*.yaml"
			],
			"fallthrough": true
		}
	],
	"assets": {
		"directory": "./public",
		"binding": "ASSETS",
		"run_worker_first": [
			"/api/*",
			"/openapi.json",
			"/swagger",
			"/scalar",
			"/health",
			"/context",
			"/docs",
			"/mcp",
			"/mcp/*"
		],
		"not_found_handling": "single-page-application"
	},
	// "secrets": [
	//   "GITHUB_TOKEN",
	//   "WORKER_API_KEY"
	// ],
	"secrets_store_secrets": [
		{
			"binding": "GITHUB_CLIENT_ID",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "CORE_GITHUB_API_GITHUB_CLIENT_ID"
		},
		{
			"binding": "GITHUB_CLIENT_SECRET",
