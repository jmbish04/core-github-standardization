	],
	// wrangler vectorize create core-github-api-vectors --preset @cf/baai/bge-large-en-v1.5
	// wrangler vectorize create core-github-api-research --dimensions=1024 --metric=cosine
	// wrangler vectorize create core-github-api-logs --preset @cf/baai/bge-large-en-v1.5
	// wrangler vectorize create core-github-api-plan-embeddings --dimensions=1024 --metric=cosine
	// wrangler vectorize create core-github-api-plan-rag --dimensions=1024 --metric=cosine
	// wrangler vectorize create core-github-api-file-embeddings --dimensions=1024 --metric=cosine
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "core-github-api-vectors",
			"remote": true
		},
		{
			"binding": "RESEARCH_INDEX",
			"index_name": "core-github-api-research",
			"remote": true
		},
		{
			"binding": "VECTORIZE_LOGS",
			"index_name": "core-github-api-logs",
			"remote": true
		},
		{
			"binding": "PLAN_EMBEDDINGS",
			"index_name": "core-github-api-plan-rag",
			"remote": true
		},
		{
			"binding": "FILE_EMBEDDINGS",
			"index_name": "core-github-api-file-embeddings",
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "core-github-api",
			"database_id": "fb7e274a-0a46-469b-8ae3-5a7750dd282b",
			"preview_database_id": "178a8586-31ee-4134-a598-cca3206123e6",
			"migrations_dir": "migrations/core"
		},
		{
			"binding": "DB_WEBHOOKS",
			"database_name": "core-github-api-webhooks",
			"database_id": "905b62db-b631-4133-8633-e0b8282d4cbd",
			"migrations_dir": "migrations/webhooks"
		}
	],
	// Email sending bindings for Email Routing
	// Targeted binding - sends only to the specified destination address
	"send_email": [
		{
			"name": "SEND_EMAIL"
		},
		{
			"name": "SEND_EMAIL_NEWSLETTER",
			"destination_address": "ai@126colby.com"
		},
		{
			"name": "Core Github API",
			"allowed_destination_addresses": [
				"ai@126colby.com"
			]
		}
	],
	// Scheduled triggers for automated tasks
	// Cron format: minute hour day month day-of-week
	"triggers": {
		"crons": [
			// Daily at 9:00 AM UTC - Triggers Research Orchestrator workflow
			// Analyzes trending GitHub repositories and sends email report
			"0 9 * * *",
			// Weekly at 2:00 AM UTC on Mondays - Scrapes AI model pricing
			// Stores pricing snapshots in D1 and alerts if data becomes stale
			"0 2 * * 1",
			// Every 3 hours - Jules Overseer Check
			"0 */3 * * *",
			// Weekly Health Suite at 3:00 AM UTC on Sundays
			"0 3 * * 7",
			// Every 6 hours - App Store AI Summary Backfill
			// Processes unsummarized apps with Worker AI and saves to D1
			"0 */6 * * *"
		]
	}
}