			},
			{
				"name": "RetrofitAgent",
				"class_name": "RetrofitAgent"
			},
			{
				"name": "ROOM_DO",
				"class_name": "RoomDO"
			},
			{
				"name": "GEMINI_AGENT",
				"class_name": "GeminiAgent"
			},
