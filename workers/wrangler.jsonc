{
	"name": "INSERT__WORKER_NAME",
	"main": "src/backend/src/index.ts",
	"compatibility_date": "INSERT__CURRENT_DATE_YYYY-MM-DD",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true,
			"persist": true,
			"head_sampling_rate": 1
		}
	},
	"vars": {
		"LOG_LEVEL": "debug",
		"AI_DEFAULT_PROVIDER": "worker-ai",
		"AI_DEFAULT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
		"GEMINI_MODEL": "gemini-3-pro-preview",
		"OPENAI_MODEL": "gpt-5.1",
		"DEFAULT_MODEL_REASONING": "@cf/openai/gpt-oss-120b",
		"DEFAULT_MODEL_STRUCTURED_RESPONSE": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
		"DEFAULT_MODEL_EMBEDDING": "@cf/baai/bge-large-en-v1.5",
		"DEFAULT_MODEL_RERANKER": "@cf/baai/bge-reranker-base",
		"AI_GATEWAY_NAME": "INSERT__WORKER_NAME",
		"CLOUDFLARE_WORKER_NAME": "INSERT__WORKER_NAME",
		"HEALTH_TEST_REPO_NAME": "testing-oktokit-commands",
		"BASE_URL": "https://INSERT__WORKER_NAME.hacolby.workers.dev",
		"MAX_AI_BUDGET": "50",
		"USE_OPENAI_MODELS": false,
		"MCP_API_URL": "https://docs.mcp.cloudflare.com/mcp"
	},
	"ai": {
		"binding": "AI"
	},
	"assets": {
		"directory": "./public",
		"binding": "ASSETS",
		"run_worker_first": [
			"/api/*",
			"/openapi.json",
			"/swagger",
			"/scalar",
			"/health",
			"/context",
			"/docs",
			"/mcp",
			"/mcp/*"
		],
		"not_found_handling": "single-page-application"
	},
	"secrets_store_secrets": [
		{
			"binding": "OPENAI_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "OPENAI_API_KEY"
		},
		{
			"binding": "CLOUDFLARE_ACCOUNT_ID",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "CLOUDFLARE_ACCOUNT_ID"
		},
		{
			"binding": "WORKER_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "WORKER_API_KEY"
		},
		{
			"binding": "AGENTIC_WORKER_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "AGENTIC_WORKER_API_KEY"
		},
		{
			"binding": "AI_GATEWAY_TOKEN",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "CLOUDFLARE_AI_GATEWAY_TOKEN"
		},
		{
			"binding": "CF_BROWSER_RENDER_TOKEN",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "CLOUDFLARE_BROWSER_RENDER_TOKEN"
		},
		{
			"binding": "STITCH_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "STITCH_API_KEY"
		},
		{
			"binding": "JULES_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "JULES_API_KEY"
		},
		{
			"binding": "GEMINI_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "GOOGLE_API_KEY"
		},
		{
			"binding": "ANTHROPIC_API_KEY",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "ANTHROPIC_API_KEY"
		},
		{
			"binding": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_1",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_1"
		},
		{
			"binding": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_2",
			"store_id": "8c42fa70938644e0a8a109744467375f",
			"secret_name": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_2"
		}
	],
	
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "INSERT__WORKER_NAME-INSERT__BUCKET_NAME"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "USE WRANGLER TO CREATE AND NAME 'INSERT__WORKER_NAME'"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "INSERT__WORKER_NAME",
			"database_id": "USE WRANGLER TO CREATE AND NAME IT 'INSERT__WORKER_NAME'",
			"migrations_dir": "migrations/core"
		}
	]
}
